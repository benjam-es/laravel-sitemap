{
    "name": "r94ever/sitemap",
    "description": "Sitemap package for Laravel.",
    "keywords": ["laravel", "php", "sitemap", "generator", "xml", "html", "google-news"],
    "license": "MIT",
    "authors": [
        {
            "name": "Van Duong Thanh",
            "email": "vandt147@outlook.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench-core": "^10.1",
        "php-coveralls/php-coveralls" : "^2.7"
    },
    "autoload": {
        "psr-4": {
            "R94ever\\Sitemap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "R94ever\\Sitemap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "R94ever\\Sitemap\\SitemapServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
